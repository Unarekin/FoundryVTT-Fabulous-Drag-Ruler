<section>
  <div class="form-group">
    <label for="{{idPrefix}}-enabled">{{localize
        "FABDRAGRULER.CONFIG.WAYPOINT.ENABLED.LABEL"
      }}</label>
    <input
      type="checkbox"
      name="config.enabled"
      id="{{idPrefix}}-enabled"
      {{checked config.enabled}}
    />
    <p class="hint">{{localize "FABDRAGRULER.CONFIG.WAYPOINT.ENABLED.HINT"}}</p>
  </div>

  <div class="form-group">
    <label for="{{idPrefix}}-radius">{{localize
        "FABDRAGRULER.CONFIG.WAYPOINT.RADIUS.LABEL"
      }}</label>
    <input
      type="number"
      step="any"
      value="{{config.style.radius}}"
      min="0"
      name="config.style.radius"
    />
    <p class="hint">{{localize "FABDRAGRULER.CONFIG.WAYPOINT.RADIUS.HINT"}}</p>
  </div>

  <div class="form-group">
    <label for="{{idPrefix}}-color">{{localize
        "FABDRAGRULER.CONFIG.WAYPOINT.COLOR.LABEL"
      }}</label>
    <color-picker
      id="{{idPrefix}}-color"
      name="config.style.color"
      value="{{config.style.color}}"
    ></color-picker>
    <p class="hint">{{localize "FABDRAGRULER.CONFIG.WAYPOINT.COLOR.HINT"}}</p>
  </div>

  <div class="form-group">
    <label for="{{idPrefix}}-alpha">{{localize
        "FABDRAGRULER.CONFIG.WAYPOINT.ALPHA.LABEL"
      }}</label>
    <range-picker
      id="{{idPrefix}}-alpha"
      name="config.style.alpha"
      min="0"
      max="1"
      step="any"
      value="{{config.style.alpha}}"
    ></range-picker>
    <p class="hint">{{localize "FABDRAGRULER.CONFIG.WAYPOINT.ALPHA.HINT"}}</p>
  </div>

  <button
    type="button"
    data-action="resetToDefault"
    style="width:100%"
  >{{localize "FABDRAGRULER.CONFIG.COMMON.RESETTODEFAULT"}}</button>
</section>